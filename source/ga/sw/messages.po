msgstr "Socraigh stadanna tab i gcoibhneas le hinneall na míre"

#. RCP3J
#: sw/inc/strings.hrc:1530
msgctxt "STR_COMPAT_OPT_TABOVERMARGIN"
msgid "Allow tabs to extend beyond the right margin"
msgstr "Lig do na cluaisíní síneadh thar an imeall deas"

