#. oKCHH
#: sw/inc/AccessibilityCheckStrings.hrc:16
msgctxt "STR_NO_ALT"
msgid "%OBJECT_NAME%"
msgstr "%OBJECT_NAME%"

#. uzcWr
#: sw/inc/AccessibilityCheckStrings.hrc:17
msgctxt "STR_LINKED_GRAPHIC"
msgid "“%OBJECT_NAME%” referenced as “%LINK%”."
msgstr "“%OBJECT_NAME%” tagartha mar “%LINK%”."

#. aPeze
#: sw/inc/AccessibilityCheckStrings.hrc:18
msgctxt "STR_TABLE_MERGE_SPLIT"
msgid "Table “%OBJECT_NAME%” contains merges or splits."
msgstr "Tá cumaisc nó scoilteanna sa tábla “%OBJECT_NAME%”."

#. bGwDb
#: sw/inc/AccessibilityCheckStrings.hrc:19
msgctxt "STR_FAKE_NUMBERING"
msgid "Simulated numbering “%NUMBERING%”."
msgstr "Uimhriú insamhalta “%NUMBERING%”."

#. jjtWE
#: sw/inc/AccessibilityCheckStrings.hrc:20
msgctxt "STR_HYPERLINK_TEXT_IS_LINK"
msgid "Hyperlink text is the same as the link address “%LINK%”."
msgstr "Is ionann téacs an hipearnaisc agus seoladh an naisc “%LINK%”."

#. BLD9h
#: sw/inc/AccessibilityCheckStrings.hrc:21
msgctxt "STR_HYPERLINK_TEXT_IS_SHORT"
msgid "Hyperlink text is too short."
msgstr "Tá téacs an hipearnaisc ró-ghearr."

#. pSpHr
#: sw/inc/AccessibilityCheckStrings.hrc:22
msgctxt "STR_HYPERLINK_NO_NAME"
msgid "Missing 'Name' property of hyperlink."
msgstr "Tá an airí 'Ainm' ar iarraidh ón hipearnasc."

#. oLvD7
#: sw/inc/AccessibilityCheckStrings.hrc:23
msgctxt "STR_LINK_TEXT_IS_NOT_NESTED"
msgid "Avoid using links and reference fields in the header or footer."
msgstr "Seachain naisc agus réimsí tagartha a úsáid sa cheanntásc nó sa bhuntásc."

#. xYUv3
#: sw/inc/AccessibilityCheckStrings.hrc:24
msgctxt "STR_TEXT_CONTRAST"
msgid "Text contrast is too low."
msgstr "Tá codarsnacht an téacs ró-íseal."

#. m5DEP
#: sw/inc/AccessibilityCheckStrings.hrc:25
msgctxt "STR_TEXT_BLINKING"
msgid "Blinking text."
msgstr "Téacs ag splancadh."

#. CQviA
#: sw/inc/AccessibilityCheckStrings.hrc:26
msgctxt "STR_AVOID_FOOTNOTES"
msgid "Avoid footnotes."
msgstr "Seachain nótaí coise."

#. MQAYK
#: sw/inc/AccessibilityCheckStrings.hrc:27
msgctxt "STR_AVOID_FAKE_FOOTNOTES"
msgid "Avoid simulated footnotes."
msgstr "Seachain nótaí coise insamhlaithe."

#. s2rjR
#: sw/inc/AccessibilityCheckStrings.hrc:28
msgctxt "STR_AVOID_FAKE_CAPTIONS"
msgid "Avoid simulated captions."
msgstr "Seachain fotheidil insamhlaithe."

#. sg2MT
#: sw/inc/AccessibilityCheckStrings.hrc:29
msgctxt "STR_AVOID_ENDNOTES"
msgid "Avoid endnotes."
msgstr "Seachain nótaí deiridh."

#. eGBcB
#: sw/inc/AccessibilityCheckStrings.hrc:30
msgctxt "STR_AVOID_BACKGROUND_IMAGES"
msgid "Avoid background images."
msgstr "Seachain íomhánna cúlra."

#. vD267
#: sw/inc/AccessibilityCheckStrings.hrc:31
msgctxt "STR_AVOID_NEWLINES_SPACE"
msgid "Avoid newlines to create space."
msgstr "Seachain línte nua chun spás a chruthú."

#. CACqA
#: sw/inc/AccessibilityCheckStrings.hrc:32
msgctxt "STR_AVOID_SPACES_SPACE"
msgid "Avoid repeated spaces."
msgstr "Seachain spásanna arís agus arís eile."

#. g5bQv
#: sw/inc/AccessibilityCheckStrings.hrc:33
msgctxt "STR_AVOID_TABS_FORMATTING"
msgid "Avoid using tabs for formatting."
msgstr "Seachain úsáid a bhaint as tabs le haghaidh formáidithe."

#. 4DWRQ
#: sw/inc/AccessibilityCheckStrings.hrc:34
msgctxt "STR_AVOID_EMPTY_NUM_PARA"
msgid "Avoid new empty lines between numbered paragraphs."
msgstr "Seachain línte folamha nua idir míreanna uimhrithe."

#. xDMGH
#: sw/inc/AccessibilityCheckStrings.hrc:35
msgctxt "STR_HEADINGS_NOT_IN_ORDER"
msgid "Outline levels of headings not in sequential order."
msgstr "Leibhéil imlíne ceannteidil nach bhfuil in ord seicheamhach."

#. Ryz5w
#: sw/inc/AccessibilityCheckStrings.hrc:36
msgctxt "STR_TEXT_FORMATTING_CONVEYS_MEANING"
msgid "The text formatting conveys additional meaning."
msgstr "Tugann formáidiú an téacs brí breise."

#. DpbCJ
#: sw/inc/AccessibilityCheckStrings.hrc:37
msgctxt "STR_NON_INTERACTIVE_FORMS"
msgid "Use interactive input fields."
msgstr "Bain úsáid as réimsí ionchuir idirghníomhacha."

#. bmMTB
#: sw/inc/AccessibilityCheckStrings.hrc:38
msgctxt "STR_FLOATING_TEXT"
msgid "Anchor Frames/Text boxes “As Character“."
msgstr "Frámaí Ancaire/Boscaí Téacs “Mar Charachtar“."

#. 77aXx
#: sw/inc/AccessibilityCheckStrings.hrc:39
msgctxt "STR_HEADING_IN_TABLE"
msgid "Tables must not contain headings."
msgstr "Ní mór ceannteidil a bheith i dtáblaí."

#. FFGhA
#: sw/inc/AccessibilityCheckStrings.hrc:40
msgctxt "STR_HEADING_ORDER"
msgid "A heading with outline level %LEVEL_CURRENT% must not follow a heading with outline level %LEVEL_PREV%."
msgstr "Ní féidir le ceannteideal le leibhéal imlíne %LEVEL_CURRENT% teacht i ndiaidh ceannteidil le leibhéal imlíne %LEVEL_PREV%."

#. 4HvTE
#: sw/inc/AccessibilityCheckStrings.hrc:41
msgctxt "STR_HEADING_START"
msgid "Outline levels should start with level 1, instead of level %LEVEL_CURRENT%."
msgstr "Ba chóir go dtosódh leibhéil imlíne le leibhéal 1, seachas leibhéal %LEVEL_CURRENT%."

#. TBXjj
#: sw/inc/AccessibilityCheckStrings.hrc:42
msgctxt "STR_FONTWORKS"
msgid "Avoid Fontwork objects in your documents. Make sure you use it for samples or other meaningless text."
msgstr "Seachain réada Fontwork i do dhoiciméid. Déan cinnte go n-úsáideann tú iad le haghaidh samplaí nó téacs eile gan bhrí."

#. EyCiU
#: sw/inc/AccessibilityCheckStrings.hrc:43
msgctxt "STR_TABLE_FORMATTING"
msgid "Avoid using empty table cells for formatting."
msgstr "Seachain cealla tábla folamh a úsáid le haghaidh formáidithe."

#. rXKK3
#: sw/inc/AccessibilityCheckStrings.hrc:44
msgctxt "STR_CONTENT_CONTROL_IN_HEADER"
msgid "Avoid content controls in header or footer."
msgstr "Seachain rialuithe ábhair sa cheanntásc nó sa bhuntásc."

#. R8FRE
#: sw/inc/AccessibilityCheckStrings.hrc:46
msgctxt "STR_DOCUMENT_DEFAULT_LANGUAGE"
msgid "Document default language is not set."
msgstr "Níl teanga réamhshocraithe an doiciméid socraithe."

#. MMD7M
#: sw/inc/AccessibilityCheckStrings.hrc:47
msgctxt "STR_STYLE_NO_LANGUAGE"
msgid "Style “%STYLE_NAME%” has no language set."
msgstr "Níl aon teanga socraithe don stíl “%STYLE_NAME%”."

#. euwJV
#: sw/inc/AccessibilityCheckStrings.hrc:48
