#. FRWsF
#: sw/inc/strings.hrc:28
msgctxt "STR_STANDARD_TOOLTIP"
msgid "Values on this tab specified in “Contains” in Organizer are removed."
msgstr "Baintear luachanna ar an táb seo atá sonraithe in “Tá” san Eagróir."

#. 9BAeq
#: sw/inc/strings.hrc:29
msgctxt "STR_STANDARD_EXTENDEDTIP"
msgid "Values in this tab are set to the corresponding values of the style specified in “Inherit from” in Organizer. In all cases, also when “Inherit from” is “None”, the current tab values specified in “Contains” are removed."
msgstr "Socraítear luachanna sa chluaisín seo chuig na luachanna comhfhreagracha den stíl atá sonraithe in “Oidhreacht ó” san Eagróir. I ngach cás, nuair a bhíonn “Oidhreacht ó” ina “Gan aon cheann”, baintear na luachanna cluaisín reatha atá sonraithe in “Tá ann”."

#. x2EUX
#: sw/inc/strings.hrc:30
msgctxt "STR_RESET_LABEL"
msgid "Reset"
msgstr "Athshocraigh"

#. o3BC2
#: sw/inc/strings.hrc:31
msgctxt "STR_RESET_TOOLTIP"
msgid "Unsaved modifications to this tab are reverted."
msgstr "Déantar modhnuithe neamhshábháilte ar an táb seo a aisiompú."

#. Sju8m
#: sw/inc/strings.hrc:32
msgctxt "STR_RESET_EXTENDEDTIP"
msgid "Revert any changes made on the current tab to the settings that were present when this dialog was opened, or after the last use of “Apply”."
msgstr "Cuir aon athruithe a rinneadh ar an táb reatha ar ais chuig na socruithe a bhí i láthair nuair a osclaíodh an dialóg seo, nó tar éis an úsáid dheireanaigh a baineadh as “Cuir i bhFeidhm”."

#. Lv4Ua
#: sw/inc/strings.hrc:33
msgctxt "STR_APPLY_LABEL"
msgid "Apply"
msgstr "Cuir i bhfeidhm"

#. BFf9A
#: sw/inc/strings.hrc:34
msgctxt "STR_APPLY_TOOLTIP"
msgid "Applies modifications on all tabs without closing dialog. Cannot be reverted with Reset."
msgstr "Cuireann sé modhnuithe i bhfeidhm ar gach cluaisín gan an dialóg a dhúnadh. Ní féidir é seo a aisiompú le Athshocraigh."

#. FbPXG
#: sw/inc/strings.hrc:35
msgctxt "STR_APPLY_EXTENDEDTIP"
msgid "Applies all modifications without closing dialog. Values are saved and cannot be reverted with Reset."
msgstr "Cuireann sé seo gach modhnú i bhfeidhm gan an dialóg a dhúnadh. Sábháiltear luachanna agus ní féidir iad a aisiompú le Athshocraigh."

