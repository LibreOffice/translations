"par_id1209200804373840\n"
"help.text"
msgid "Paragraphs formatted with one of the predefined paragraph styles (вҖңHeading 1вҖ“10вҖқ) have an outline level that corresponds to the number in the paragraph style. You can also assign outline levels to paragraphs in the <link href=\"text/swriter/01/05030800.xhp\">Outline & List</link> tab page of the Format - Paragraph dialog."
msgstr ""

