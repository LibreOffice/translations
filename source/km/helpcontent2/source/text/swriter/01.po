msgctxt ""
"05060100.xhp\n"
"par_id631629220309961\n"
"help.text"
msgid "<emph>Baseline:</emph> available only for \"As character\" anchoring, this option will position the object considering the text baseline over which all characters are placed."
msgstr ""

#. xYbGQ
