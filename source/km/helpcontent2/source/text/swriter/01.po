#: 05060100.xhp
msgctxt ""
"05060100.xhp\n"
"par_id631629212021233\n"
"help.text"
msgid "<menuitem>Line of text</menuitem>: available only for \"To character\" anchoring, the object is positioned considering the height of the line of text where the anchor is placed."
