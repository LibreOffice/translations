msgctxt ""
"01130000.xhp\n"
"bm_id3154621\n"
"help.text"
msgid "<bookmark_value>printing; documents</bookmark_value><bookmark_value>documents; printing</bookmark_value><bookmark_value>text documents; printing</bookmark_value><bookmark_value>spreadsheets; printing</bookmark_value><bookmark_value>presentations; print menu</bookmark_value><bookmark_value>drawings; printing</bookmark_value><bookmark_value>choosing printers</bookmark_value><bookmark_value>printers; choosing</bookmark_value><bookmark_value>print area selection</bookmark_value><bookmark_value>selecting; print areas</bookmark_value><bookmark_value>pages; selecting one to print</bookmark_value><bookmark_value>printing; selections</bookmark_value><bookmark_value>printing; copies</bookmark_value><bookmark_value>copies; printing</bookmark_value><bookmark_value>spoolfiles with Xprinter</bookmark_value>"
msgstr "<bookmark_value>бһҖбһ¶бһҡвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–; бһҜбһҖбһҹбһ¶бһҡ</bookmark_value><bookmark_value>бһҜбһҖбһҹбһ¶бһҡ; бһҖбһ¶бһҡвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһҜбһҖбһҹбһ¶бһҡвҖӢбһўбһҸбҹ’бһҗбһ”бһ‘; бһҖбһ¶бһҡвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһҹбҹҖбһңбһ—бҹ…вҖӢбһ”бһүбҹ’бһҮбһё; бһҖбһ¶бһҡвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһҖбһ¶бһҡвҖӢбһ”бһ„бҹ’бһ бһ¶бһү; бһҳбҹүбһәбһ“бһ»бһҷвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһӮбҹҶбһ“бһјбһҡ; бһҖбһ¶бһҡвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһҖбһ¶бһҡвҖӢбһҮбҹ’бһҡбһҫбһҹвҖӢбһҳбҹүбһ¶бһҹбҹҠбһёбһ“вҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһҳбҹүбһ¶бһҹбҹҠбһёбһ“вҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–; бһҖбһ¶бһҡвҖӢбһҮбҹ’бһҡбһҫбһҹ</bookmark_value><bookmark_value>бһҮбһҳбҹ’бһҡбһҫбһҹвҖӢбһ•бҹ’бһ‘бҹғбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһҖбһ¶бһҡвҖӢбһҮбҹ’бһҡбһҫбһҹвҖӢбһҡбһҫбһҹ; бһ•бҹ’бһ‘бҹғвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһ‘бҹҶбһ–бҹҗбһҡ; бһҖбһ¶бһҡвҖӢбһҮбҹ’бһҡбһҫбһҹвҖӢбһҡбһҫбһҹвҖӢбһҷбһҖвҖӢбһҳбһҪбһҷвҖӢбһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһҖбһ¶бһҡвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–; бһҮбһҳбҹ’бһҡбһҫбһҹ</bookmark_value><bookmark_value>бһҖбһ¶бһҡвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–; бһ…бҹ’бһ”бһ¶бһ”бҹӢвҖӢбһ…бһҳбҹ’бһӣбһ„</bookmark_value><bookmark_value>бһ…бҹ’бһ”бһ¶бһ”бҹӢвҖӢбһ…бһҳбҹ’бһӣбһ„; бһҖбһ¶бһҡвҖӢбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–</bookmark_value><bookmark_value>бһҜбһҖбһҹбһ¶бһҡвҖӢбһ бһ»бһ„вҖӢбһҡбһ”бһҹбҹӢвҖӢбһ“бһ№бһ„ Xprinter</bookmark_value>"

