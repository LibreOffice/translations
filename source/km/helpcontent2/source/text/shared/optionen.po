msgctxt ""
"01010501.xhp\n"
"par_id3148947\n"
"help.text"
msgid "<ahelp hid=\".\">With the vertical color component slider you can modify the value of each component of the color.</ahelp> With the large colored square you can select the color component approximately."
msgstr ""

